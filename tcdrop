#include <linux/bpf.h>
#include <linux/pkt_cls.h>
#include <linux/ip.h>
#include <bpf/bpf_helpers.h>
#include <bpf/bpf_endian.h>

#define RATE        10        // tokens per second
#define BSIZE       20        // max bucket size
#define NS_PER_SEC  1000000000ULL

struct bucket {
    __u64 tokens;
    __u64 last_time;
};

struct {
    __uint(type, BPF_MAP_TYPE_HASH);
    __uint(max_entries, 1024);
    __type(key, __u32);          // src IP
    __type(value, struct bucket);
} token_buckets SEC(".maps");

SEC("tc")
int tc_token_bucket(struct __sk_buff *skb) {

    // 1. parse src IP
    struct iphdr *ip;
    void *data     = (void *)(long)skb->data;
    void *data_end = (void *)(long)skb->data_end;

    if (data + sizeof(struct ethhdr) + sizeof(struct iphdr) > data_end)
        return TC_ACT_OK;

    ip = data + sizeof(struct ethhdr);
    __u32 src_ip = ip->saddr;

    // 2. look up or init bucket for  IP
    struct bucket *b = bpf_map_lookup_elem(&token_buckets, &src_ip);
    if (!b) {
        struct bucket new_bucket = {};
        new_bucket.tokens    = BURST;
        new_bucket.last_time = now;
        bpf_map_update_elem(&token_buckets, &src_ip, &new_bucket, BPF_NOEXIST);
        b = bpf_map_lookup_elem(&token_buckets, &src_ip);
        if (!b) return TC_ACT_OK;
    }

    // 4. refill tokens
    __u64 elapsed = now - b->last_time;
    __u64 new_tokens = b->tokens + (RATE * elapsed) / NS_PER_SEC;
    b->tokens    = new_tokens > BURST ? BURST : new_tokens;
    b->last_time = now;

    // 5. drop or pass
    if (b->tokens < 1) {
        return TC_ACT_SHOT;
    }

    // 6. decrement
    b->tokens--;

    return TC_ACT_OK;
}

